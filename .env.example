# ═══════════════════════════════════════════════════
#  Temple Digital Group — Trading Bot
#  Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════

# ── Temple Credentials (from app.templedigitalgroup.com) ──
TEMPLE_EMAIL=your@email.com
TEMPLE_PASSWORD=your_password_here

# ── Temple API Endpoints ──────────────────────────────────
TEMPLE_REST_URL=https://api.templedigitalgroup.com
TEMPLE_WS_URL=wss://api.templedigitalgroup.com/ws

# ── Trading Parameters ────────────────────────────────────
# Comma-separated trading pairs (Canton-native assets)
TRADING_PAIRS=BTC-USDCx,ETH-USDCx

# Candle interval: 1m | 5m | 15m | 1h | 4h | 1d
CANDLE_INTERVAL=5m

# Order sizing (in USD notional per trade)
ORDER_SIZE_USD=1000

# Risk limits
MAX_TOTAL_EXPOSURE_USD=50000
MAX_DAILY_LOSS_USD=2000
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# ── MA Strategy ───────────────────────────────────────────
MA_TYPE=ema           # ema | sma
FAST_PERIOD=9
SLOW_PERIOD=21
USE_RSI_FILTER=true
USE_VOLUME_FILTER=true

# ── Safety ───────────────────────────────────────────────
# Set to false ONLY when ready for live trading!
DRY_RUN=true
LOG_LEVEL=info        # debug | info | warn | error
